{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "TuringDB",
  "colors": {
    "primary": "#4DFF88",
    "light": "#7DFFA8",
    "dark": "#21CC5E"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "dark": "#0B0B0C"
    }
  },
  "fonts": {
    "heading": {
      "family": "Ark Pixel",
      "source": "/fonts/ArkPixel16px-Latin.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "IBM Plex Sans",
      "weight": 300,
      "source": "/fonts/IBMPlexSans-Light.woff2",
      "format": "woff2"
    }
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "TuringDB",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "quickstart",
              "claude-skill",
              "commands"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/overview",
              "concepts/columnar_storage",
              "concepts/versioning_system",
              "concepts/dataparts",
              "concepts/zero_locking",
              "concepts/snapshots"
            ]
          },
          {
            "group": "Benchmarks",
            "pages": [
              "benchmarks/results-summary",
              "benchmarks/technical-report"
            ]
          },
          {
            "group": "Query Language",
            "pages": [
              "query/cypher_subset",
              "query/cheatsheet"
            ]
          },
          {
            "group": "Importing data",
            "pages": [
              "import_data/jsonl",
              "import_data/csv",
              "import_data/neo4j",
              "import_data/gml",
              "import_data/parquet"
            ]
          },
          {
            "group": "Graph Development",
            "pages": [
              "graph_dev/create_graph",
              "graph_dev/load_graph",
              "graph_dev/load_external",
              "graph_dev/create_change",
              "graph_dev/list_changes",
              "graph_dev/create_nodes_edges",
              "graph_dev/update_properties",
              "graph_dev/submit_change",
              "graph_dev/time_travelling",
              "graph_dev/graph_examples"
            ]
          },
          {
            "group": "Vector Search",
            "pages": [
              "vector-search"
            ]
          },
          {
            "group": "Graph Algorithms",
            "pages": [
              "shortest-path"
            ]
          },
          {
            "group": "Tutorials",
            "pages": [
              "tutorials/example_notebooks"
            ]
          },
          {
            "group": "Python SDK",
            "pages": [
              "pythonsdk/get_started",
              "pythonsdk/reference"
            ]
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "troubles/troubles"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/turingdb_logo.png",
    "dark": "/logo/logo_turingdb_thick.png"
  },
  "navbar": {
    "links": [{
        "label": "Discord",
        "href": "https://discord.gg/dMM48ns5VY"
      },
      {
        "label": "GitHub",
